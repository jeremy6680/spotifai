# Environment & secrets — NEVER baked into the image
.env
.env.*
!.env.example

# DuckDB data — mounted as volume, not baked in the image
data/
*.duckdb

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Virtual environment
venv/
.venv/
env/

# Git
.git/
.gitignore

# Dev tools
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.log

# OS
.DS_Store
Thumbs.db

# Docker files (no need to copy them into the image)
Dockerfile
docker-compose.yml
.dockerignore